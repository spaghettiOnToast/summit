    "@eslint/js": "^9.39.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "@types/react-test-renderer": "18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.1.1",
    "@vitest/eslint-plugin": "^1.3.23",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
