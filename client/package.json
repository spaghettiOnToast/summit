{
  "name": "summit",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.14.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:parity": "tsx scripts/test-live-beast-stats-parity.ts",
    "lint": "eslint . --cache --cache-strategy content --cache-location .cache/eslint --concurrency auto",
    "lint:ci": "eslint . --max-warnings=0 --report-unused-inline-configs error",
    "lint:stats": "eslint . --stats",
    "lint:suppress:any:init": "eslint . --rule '{\"@typescript-eslint/no-explicit-any\":\"error\"}' --suppress-all --suppressions-location .eslint-suppressions.json",
    "lint:suppress:any:check": "eslint . --rule '{\"@typescript-eslint/no-explicit-any\":\"error\"}' --suppressions-location .eslint-suppressions.json",
    "lint:suppress:prune": "eslint . --rule '{\"@typescript-eslint/no-explicit-any\":\"error\"}' --suppressions-location .eslint-suppressions.json --prune-suppressions",
    "preview": "vite preview",
    "serve": "vite preview",
    "typecheck:strict": "tsc -p tsconfig.strict.json --noEmit"
  },
  "dependencies": {
    "@cartridge/connector": "^0.12.1",
    "@cartridge/controller": "^0.12.1",
