    "@tanstack/react-virtual": "^3.13.12",
    "@types/uuid": "^10.0.0",
    "framer-motion": "^12.7.4",
    "graphql-request": "^7.1.2",
    "immer": "^10.1.1",
    "lottie-react": "^2.4.1",
    "notistack": "^3.0.2",
    "open": "^10.1.0",
    "react": "^18.2.0",
    "react-device-detect": "^2.2.3",
    "react-dom": "^18.2.0",
